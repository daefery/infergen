// Auto-generated by Infergen. Do not edit — run `infergen generate` to regenerate.
// infergen-core v0.0.0 · catalog schema v1

/** A provider that receives analytics events. */
export interface Provider {
  /** Unique provider identifier, e.g. "posthog". */
  id: string;
  /** Send a single analytics event. */
  track(eventName: string, properties: Record<string, unknown>): void;
  /** Flush buffered events (optional). */
  flush?(): void;
  /** Shut down the provider (optional). */
  shutdown?(): void;
}

/** Runtime configuration. Pass to `configureInfergen` at app startup. */
export interface InfergenConfig {
  /** Analytics providers that receive every `track` call. */
  providers: Provider[];
  /** Initial consent state. Default: "unknown" (permissive until explicitly set). */
  consent?: ConsentState;
  /** Initial region tag for provider routing (e.g. "eu", "us"). */
  region?: string;
  /** Initial per-property redaction hook. */
  redactFn?: RedactFn;
}

/** @internal Registered providers — populated by `configureInfergen`. */
let _providers: Provider[] = [];

/** Configure the Infergen runtime. Call once before any track calls. */
export function configureInfergen(config: InfergenConfig): void {
  _providers = config.providers;
  if (config.consent !== undefined) setConsent(config.consent);
  if (config.region !== undefined) setRegion(config.region);
  if (config.redactFn !== undefined) setRedactFn(config.redactFn);
}

// ─── Delivery Engine ────────────────────────────────────────────────────────────

/** Options for DeliveryEngine. */
export interface DeliveryOptions {
  /** Number of events to collect before an automatic flush. Default: 10. */
  batchSize?: number;
  /** Milliseconds between timer-driven flushes. 0 disables the timer. Default: 5000. */
  flushInterval?: number;
  /** Maximum delivery attempts per event before it is dropped. Default: 3. */
  maxRetries?: number;
  /** Base retry delay in milliseconds; doubles each attempt (exponential backoff). Default: 1000. */
  retryDelay?: number;
  /** Fraction of events to forward (0.0 = drop all, 1.0 = forward all). Default: 1.0. */
  sampleRate?: number;
  /** Maximum number of queued events. Oldest is dropped when the queue is full. Default: 1000. */
  maxQueueSize?: number;
  /**
   * Persistence key for the event queue.
   * Browser: key in localStorage. Omit for in-memory queue only.
   */
  persistenceKey?: string;
}

/** @internal Queued event payload — compact keys keep storage small. */
interface _QueuedEvent {
  n: string;
  p: Record<string, unknown>;
}

/**
 * Wraps a {@link Provider} with batching, retry, sampling, and flush-on-exit.
 *
 * @example
 * ```ts
 * configureInfergen({
 *   providers: [withDelivery(new PostHogProvider({ apiKey: "phc_..." }))],
 * });
 * ```
 */
export class DeliveryEngine implements Provider {
  readonly id: string;
  private _q: _QueuedEvent[] = [];
  private _timer: ReturnType<typeof setInterval> | null = null;
  private _flushing = false;
  private readonly _o: Required<Omit<DeliveryOptions, "persistenceKey">> & { persistenceKey?: string };

  constructor(private readonly _inner: Provider, opts: DeliveryOptions = {}) {
    this.id = `delivery:${_inner.id}`;
    this._o = {
      batchSize:     opts.batchSize     ?? 10,
      flushInterval: opts.flushInterval ?? 5000,
      maxRetries:    opts.maxRetries    ?? 3,
      retryDelay:    opts.retryDelay    ?? 1000,
      sampleRate:    opts.sampleRate    ?? 1.0,
      maxQueueSize:  opts.maxQueueSize  ?? 1000,
      persistenceKey: opts.persistenceKey,
    };
    this._load();
    this._startTimer();
    this._exitHook();
  }

  track(eventName: string, properties: Record<string, unknown>): void {
    if (this._o.sampleRate < 1.0 && Math.random() > this._o.sampleRate) return;
    if (this._q.length >= this._o.maxQueueSize) this._q.shift();
    this._q.push({ n: eventName, p: properties });
    this._save();
    if (this._q.length >= this._o.batchSize) void this._flush();
  }

  flush(): void { void this._flush(); }

  shutdown(): void { this._stopTimer(); void this._flush(); }

  private _startTimer(): void {
    if (this._o.flushInterval > 0) {
      this._timer = setInterval(() => void this._flush(), this._o.flushInterval);
      const t = this._timer as unknown as { unref?: () => void };
      if (typeof t.unref === "function") t.unref();
    }
  }

  private _stopTimer(): void {
    if (this._timer !== null) { clearInterval(this._timer); this._timer = null; }
  }

  private async _flush(): Promise<void> {
    if (this._flushing || this._q.length === 0) return;
    this._flushing = true;
    try {
      const batch = this._q.splice(0, this._o.batchSize);
      this._save();
      await Promise.all(batch.map(e => this._deliver(e)));
    } finally {
      this._flushing = false;
    }
  }

  private async _deliver(e: _QueuedEvent): Promise<void> {
    for (let i = 0; i <= this._o.maxRetries; i++) {
      try { this._inner.track(e.n, e.p); return; } catch { /* retry */ }
      if (i < this._o.maxRetries)
        await new Promise<void>(r => setTimeout(r, this._o.retryDelay * (2 ** i)));
    }
  }

  private _save(): void {
    const key = this._o.persistenceKey;
    if (!key) return;
    try {
      if (typeof localStorage !== "undefined") localStorage.setItem(key, JSON.stringify(this._q));
    } catch { /* storage quota or unavailable */ }
  }

  private _load(): void {
    const key = this._o.persistenceKey;
    if (!key) return;
    try {
      if (typeof localStorage !== "undefined") {
        const raw = localStorage.getItem(key);
        if (raw) this._q = JSON.parse(raw) as _QueuedEvent[];
      }
    } catch { /* ignore corrupt data */ }
  }

  private _exitHook(): void {
    if (typeof process !== "undefined" && typeof process.on === "function") {
      process.on("beforeExit", () => this.shutdown());
    } else if (typeof window !== "undefined") {
      window.addEventListener("visibilitychange", () => {
        if (document.visibilityState === "hidden") this.flush();
      });
    }
  }
}

/** Wrap a provider in a {@link DeliveryEngine} with optional delivery options. */
export function withDelivery(provider: Provider, opts?: DeliveryOptions): DeliveryEngine {
  return new DeliveryEngine(provider, opts);
}

// ─── Consent & PII Controls ─────────────────────────────────────────────────────

/** Consent state for analytics event dispatch. */
export type ConsentState = "granted" | "denied" | "unknown";

/**
 * A function that transforms or redacts a single event property before dispatch.
 * Return the (possibly transformed) value to include the property.
 * Return `null` to drop the property entirely from the dispatched payload.
 */
export type RedactFn = (
  propertyName: string,
  value: unknown,
  eventName: string,
) => unknown | null;

/** @internal Current consent state — defaults to "unknown" (permissive until explicitly set). */
let _consentState: ConsentState = "unknown";
/** @internal Whether the user has globally opted out of all tracking. */
let _optedOut = false;
/** @internal Property-level redaction hook registered via setRedactFn. */
let _redactFn: RedactFn | null = null;
/** @internal Active region tag for provider routing. */
let _region: string | null = null;
/** @internal Region-to-provider-id routing table. */
let _regionRoutes: Record<string, string[]> = {};

/** Set the current consent state. "denied" blocks all event dispatch. */
export function setConsent(state: ConsentState): void {
  _consentState = state;
}

/** Get the current consent state. */
export function getConsent(): ConsentState {
  return _consentState;
}

/** Globally opt out of all analytics tracking. No events are dispatched until optIn() is called. */
export function optOut(): void {
  _optedOut = true;
}

/** Opt back in to analytics tracking. */
export function optIn(): void {
  _optedOut = false;
}

/** Returns true when the user has opted out of all analytics. */
export function isOptedOut(): boolean {
  return _optedOut;
}

/** Register a per-property redaction hook, or pass null to clear. */
export function setRedactFn(fn: RedactFn | null): void {
  _redactFn = fn;
}

/** Set the active region tag (e.g. "eu", "us"). Used for provider routing. */
export function setRegion(region: string | null): void {
  _region = region;
}

/** Get the active region tag. */
export function getRegion(): string | null {
  return _region;
}

/**
 * Configure region-based provider routing.
 * Keys are region tags; values are arrays of provider ids that should receive
 * events when that region is active. Providers not in the list are skipped.
 *
 * @example
 * setRegionRoutes({ eu: ["posthog-eu"], us: ["posthog-us", "amplitude"] });
 */
export function setRegionRoutes(routes: Record<string, string[]>): void {
  _regionRoutes = routes;
}

/**
 * @internal
 * Central dispatch — applies consent gate, opt-out, PII redaction, and region
 * routing before forwarding to providers. All generated track functions call this.
 */
export function _dispatch(
  eventName: string,
  properties: Record<string, unknown>,
): void {
  // Opt-out and consent gate
  if (_optedOut || _consentState === "denied") return;

  // PII redaction
  let payload: Record<string, unknown> = properties;
  if (_redactFn !== null) {
    payload = {};
    for (const [key, value] of Object.entries(properties)) {
      const result = _redactFn(key, value, eventName);
      if (result !== null) payload[key] = result;
    }
  }

  // Region routing: filter providers to those allowed for the current region
  let targets = _providers;
  if (_region !== null && _regionRoutes[_region] !== undefined) {
    const allowed = _regionRoutes[_region];
    targets = _providers.filter(p => allowed.includes(p.id));
  }

  targets.forEach(p => p.track(eventName, payload));
}

/** All tracked event names. */
export type EventName =
  | "checkout_completed"
  | "page_viewed"
  | "product_added_to_cart"
  | "user_signed_in";

// ─── checkout_completed ────────────────────────────────────────────────

/** Properties for the checkout_completed event. */
export interface CheckoutCompletedProperties {
  /** @type {string} */
  currency: string;
  /** @type {string} */
  order_id: string;
  /** @type {number} */
  total: number;
}

/**
 * Track a checkout_completed event.
 *
 * User completed the checkout flow.
 */
export function trackCheckoutCompleted(properties: CheckoutCompletedProperties): void {
  _dispatch("checkout_completed", properties);
}

